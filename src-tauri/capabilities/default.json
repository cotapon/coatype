{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for CoAType",
  "windows": ["settings", "overlay", "update-dialog"],
  "permissions": [
    "core:default",
    "shell:default",
    "fs:default",
    "dialog:default",
    "updater:default",
    "process:default",
    "core:window:allow-show",
    "core:window:allow-close",
    "core:window:allow-center",
    "core:window:allow-set-focus",
    "core:window:allow-set-shadow"
  ]
}
